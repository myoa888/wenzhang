@echo off
chcp 65001 >nul
echo === 1. 登录获取 Token ===
curl -s -X POST https://wenzhang.dingdingoa.cn/api/auth/login ^
  -H "Content-Type: application/json" ^
  -d "{\"username\":\"admin\",\"password\":\"mima2012\"}" > login_response.json

findstr "token" login_response.json >nul
if errorlevel 1 (
  echo 登录失败
  type login_response.json
  goto :end
)

:: 提取 token（简单处理）
for /f "tokens=2 delims=:, " %%i in ('findstr "token" login_response.json') do set TOKEN=%%i
set TOKEN=%TOKEN:"=%
set TOKEN=%TOKEN:,=%
set TOKEN=%TOKEN:=%
echo Token: %TOKEN%

:: 创建测试图片（1x1 红色 PNG）
echo === 2. 创建测试图片 ===
powershell -Command "[System.IO.File]::WriteAllBytes('test.png', [byte[]](0x89,0x50,0x4E,0x47,0x0D,0x0A,0x1A,0x0A,0x00,0x00,0x00,0x0D,0x49,0x48,0x44,0x52,0x00,0x00,0x00,0x01,0x00,0x00,0x00,0x01,0x08,0x02,0x00,0x00,0x00,0x90,0x77,0x53,0xDE,0x00,0x00,0x00,0x0C,0x49,0x44,0x41,0x54,0x08,0xD7,0x63,0xF8,0xCF,0xC0,0x00,0x00,0x00,0x03,0x00,0x01,0x00,0x18,0xDD,0x8D,0xB4,0x00,0x00,0x00,0x00,0x49,0x45,0x4E,0x44,0xAE,0x42,0x60,0x82))"

:: 上传图片
echo === 3. 上传图片 ===
curl -s -X POST https://wenzhang.dingdingoa.cn/api/upload ^
  -H "Authorization: Bearer %TOKEN%" ^
  -F "image=@test.png" ^
  -v

echo.
echo === 上传完成 ===

:: 清理
del login_response.json test.png 2>nul
:end
pause
