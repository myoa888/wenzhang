#!/bin/sh
# Git auto-push hook - 自动推送到远程仓库
# 位置: .githooks/post-commit

# 获取当前分支
BRANCH=$(git rev-parse --abbrev-ref HEAD)

echo ""
echo "========================================"
echo "开始自动推送..."
echo "分支: $BRANCH"
echo "========================================"

# 推送到 GitHub
echo ""
echo "正在推送到 GitHub..."
git push origin $BRANCH

# 推送到 Gitee (如果存在)
if git remote | grep -q "gitee"; then
    echo ""
    echo "正在推送到 Gitee..."
    git push gitee $BRANCH
fi

echo ""
echo "========================================"
echo "推送完成!"
echo "========================================"
